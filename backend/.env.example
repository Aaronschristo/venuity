# ============================================================================
# Venuity Backend — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================================

# ---------------------------------------------------------------------------
# Core Security
# ---------------------------------------------------------------------------
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-real-secret-key

# Set to False in production. NEVER run production with DEBUG=True.
DEBUG=True

# Comma-separated list of allowed hostnames.
# Example: ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com
ALLOWED_HOSTS=127.0.0.1,localhost

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SQLite (default for development):
#   Leave DATABASE_URL empty or omit — SQLite is used automatically.
#
# PostgreSQL (recommended for production):
#   DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_URL=

# ---------------------------------------------------------------------------
# CORS — Cross-Origin Resource Sharing
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins (frontend URLs).
# Example: CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourapp.com
# For development, you can use CORS_ALLOW_ALL=True (NOT for production).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:1420,http://127.0.0.1:1420
CORS_ALLOW_ALL=True

# ---------------------------------------------------------------------------
# JWT Token Lifetimes
# ---------------------------------------------------------------------------
# Access token lifetime in hours
ACCESS_TOKEN_LIFETIME_HOURS=8

# Refresh token lifetime in days
REFRESH_TOKEN_LIFETIME_DAYS=7
